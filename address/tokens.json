{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Dark, image-led entertainment design system extracted from mtv.de — black canvas, electric MTV yellow, and the Gravity typeface.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.969,
          0.976,
          0.031
        ],
        "hex": "#f7f908"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.667,
          0.804
        ],
        "hex": "#00aacd"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.071,
          0.071,
          0.071
        ],
        "hex": "#121212"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.953,
          0.953,
          0.953
        ],
        "hex": "#f3f3f3"
      }
    },
    "on-surface-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.631,
          0.631,
          0.631
        ],
        "hex": "#a1a1a1"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "xxl": {
      "$value": {
        "value": 40,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    }
  },
  "typography": {
    "headline-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 36,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "title-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 350
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 14,
          "unit": "px"
        },
        "fontWeight": 350
      }
    },
    "label-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 700,
        "lineHeight": 32
      }
    },
    "label-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 14,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Gravity",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 700
      }
    }
  }
}